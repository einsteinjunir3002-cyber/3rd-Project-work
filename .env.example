# SmartLearn AI LMS - Environment Configuration Template

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Settings
# For a local MongoDB instance: mongodb://localhost:27017/smartlearn
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster0.mongodb.net/smartlearn
MONGODB_URI=mongodb://localhost:27017/smartlearn

# Security and JWT Authentication
JWT_SECRET=supersecretjwtkey1234567890!
JWT_EXPIRES_IN=7d

# File Upload Options (local, s3, or cloudinary)
UPLOAD_STORAGE=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET_NAME=

# --- REAL AI INTEGRATION PROVIDERS (At least one must be configured) ---
# Primary Google Gemini API key (Free Tier supported)
GEMINI_API_KEY=

# Optional Fallback/Alternative AI Providers
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# Social Login Options (Passport Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# SMTP Email Verification & Password Recovery Settings
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@smartlearn.edu
